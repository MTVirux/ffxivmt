{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FfmtLogging": {
    "LogDirectory": "logs",
    "ChannelsEnabled": [
      "ERROR",
      "API_INFO",
      "API_ERROR",
      "SCYLLA_DB",
      "SCYLLA_GILFLUX",
      "SCYLLA_SALES",
      "SCYLLA_SALES_ERROR",
      "UNIVERSALIS_API",
      "DB_UPDATE_ACTIVATIONS"
    ],
    "MirrorToAllLog": false,
    "FileRetainedFileCount": 14,
    "FileRollingSizeBytes": 104857600
  },
  "Scylla": {
    "ContactPoints": [ "ffmt_scylla_node" ],
    "Port": 9042,
    "Keyspace": "ffmt",
    "QueryTimeoutMillis": 12000
  },
  "Elastic": {
    "Url": "http://ffmt_elastic:9200",
    "ItemsIndex": "items",
    "RequestTimeoutSeconds": 10
  },
  "Universalis": {
    "BaseUrl": "https://universalis.app/api/v2/",
    "MaxRetries": 20,
    "InitialBackoffSeconds": 0.2,
    "MaxBackoffSeconds": 10.0,
    "RequestTimeoutSeconds": 30
  },
  "Garland": {
    "BaseUrl": "https://www.garlandtools.org/db/doc/",
    "MaxRetries": 20,
    "InitialBackoffSeconds": 0.2,
    "MaxBackoffSeconds": 10.0,
    "RequestTimeoutSeconds": 30
  },
  "Gilflux": {
    "RankingCacheSeconds": 20,
    "WorldStructureCacheSeconds": 300,
    "RankingUpdateMaxConcurrency": 0,
    "TimeframesMs": [ 3600000, 10800000, 21600000, 43200000, 86400000, 259200000, 604800000 ]
  }
}
