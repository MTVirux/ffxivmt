# Existing
docker/scylla/persistent

# .NET build outputs — scoped to project paths so docker/scylla/usr/local/bin
# (a source dir mirroring the Scylla image's /usr/local/bin) isn't excluded.
backend/**/bin
backend/**/obj
docker/ws_worker/**/bin
docker/ws_worker/**/obj

# Frontend build outputs and deps
frontend/node_modules
frontend/dist
frontend/.pnpm-store

# VCS / editor state
.git
.gitattributes
.gitignore
.vscode
.idea

# Runtime state
logs
**/*.log
.env

# Test artifacts
backend/**/TestResults
backend/**/.coverage

# OS metadata
.DS_Store
Thumbs.db

# Old PHP-era leftovers still in the tree
docker/ws_worker_old_python
docker/backend/etc/apache2
