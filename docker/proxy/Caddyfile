# ACME state persists in the caddy_data named volume so recreates don't re-issue.
# `handle` (not `handle_path`) preserves the full request path — the .NET endpoints
# expect /api/v1/... intact.

{
    email {$ZERO_SSL_USER_EMAIL}
}

{$ZERO_SSL_MAIN_DOMAIN} {
    encode gzip zstd

    handle /api/* {
        reverse_proxy ffmt_backend:8080
    }

    handle /health* {
        reverse_proxy ffmt_backend:8080
    }
    handle /openapi/* {
        reverse_proxy ffmt_backend:8080
    }

    handle {
        reverse_proxy ffmt_frontend:80
    }
}

{$ZERO_SSL_MONITORING_DOMAIN} {
    encode gzip zstd
    reverse_proxy ffmt_grafana:3000
}
