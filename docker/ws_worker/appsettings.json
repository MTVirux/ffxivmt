{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Scylla": {
    "ContactPoints": [ "ffmt_scylla_node" ],
    "Port": 9042,
    "Keyspace": "ffmt",
    "QueryTimeoutMillis": 12000
  },
  "Universalis": {
    "WsUrl": "wss://universalis.app/api/ws",
    "ApiUrl": "https://universalis.app/api/v2/",
    "RegionsToUse": ["Europe", "North-America"],
    "RegionsToImport": ["Europe"],
    "ItemsPerRequest": 100,
    "MaxRequestsPerSecond": 25,
    "MaxRequestsPerSecondBurst": 50
  },
  "Gilflux": {
    "CoalesceWindowSeconds": 2.0,
    "Workers": 8,
    "QueueMax": 1000,
    "HttpTimeoutSeconds": 10
  },
  "Backfill": {
    "ChunkDays": 7,
    "LiveGapIntervalMinutes": 15,
    "HistoricalCrawlIntervalMinutes": 60,
    "SkipIfGapUnderMinutes": 5
  }
}
