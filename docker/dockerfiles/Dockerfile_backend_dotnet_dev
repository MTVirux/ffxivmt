# Dev image for the .NET backend. Built on the SDK so `dotnet watch` works; paired with the
# `./backend:/src/backend` bind-mount in docker-compose.dev.yml so source edits
# on the host trigger an in-container rebuild.

FROM mcr.microsoft.com/dotnet/sdk:9.0

WORKDIR /src/backend

# Polling watcher works around the lack of inotify across some bind-mount setups.
ENV ASPNETCORE_URLS=http://0.0.0.0:8080 \
    ASPNETCORE_ENVIRONMENT=Development \
    DOTNET_USE_POLLING_FILE_WATCHER=true \
    DOTNET_RUNNING_IN_CONTAINER=true \
    DOTNET_GCServer=0

EXPOSE 8080

ENTRYPOINT ["dotnet", "watch", "--project", "Ffmt.Api/Ffmt.Api.csproj", "run", "--no-launch-profile"]
